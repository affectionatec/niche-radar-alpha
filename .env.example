# -- Reddit (required — free at https://www.reddit.com/prefs/apps) --
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=NicheRadar/0.1 by YourUsername

# -- Google Trends --
# No credentials needed — trendspyg works without an API key.

# -- Hacker News --
# No credentials needed — official Firebase API is public.

# -- GitHub Trending --
# No credentials needed for scraping. Optional PAT for higher rate limits:
GITHUB_TOKEN=

# -- YouTube (optional — enables richer data) --
YOUTUBE_API_KEY=

# -- X / Twitter (optional — any ONE backend enables X capture) --
# Backends are tried in order: xAI → Xquik → cookie auth. The API-key paths
# need no cookies or scraping and are far more stable. Can also be set per-
# source from Settings → Data Sources → Twitter / X.
XAI_API_KEY=            # console.x.ai — xAI live X search (recommended)
XQUIK_API_KEY=          # xquik.com — REST API with full engagement metrics
# Cookie fallback (brittle): set X_CT0 and X_AUTH_TOKEN from your x.com cookies.
X_CT0=
X_AUTH_TOKEN=

# -- Bluesky (optional — free app password enables pain-point search) --
# Create an app password at https://bsky.app/settings/app-passwords
BSKY_HANDLE=
BSKY_APP_PASSWORD=

# -- ScrapeCreators (optional — one key enables TikTok, Instagram, Threads) --
# Get a key at https://scrapecreators.com
SCRAPECREATORS_API_KEY=

# -- Database --
DATABASE_URL=sqlite:///data/niche_radar.db
# For PostgreSQL: DATABASE_URL=postgresql://radar:changeme@db:5432/niche_radar

# -- Scheduler --
COLLECTION_INTERVAL_HOURS=4
ANALYSIS_INTERVAL_HOURS=6
CLEANUP_HOUR_UTC=3

# -- Retry --
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2

# -- Data Retention (days) --
RETENTION_RAW_ITEMS=90
RETENTION_ARCHIVED_NICHES=180
RETENTION_COLLECTION_RUNS=30

# -- Report --
REPORT_OUTPUT_DIR=./reports
REPORT_FORMAT=both

# -- Logging --
LOG_LEVEL=INFO
LOG_FORMAT=json

# -- Notifications (optional) --
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# -- LLM (can also be set in the frontend Settings page) --
LLM_PROVIDER=openai_compat        # 'openai_compat' or 'anthropic'
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com  # leave empty for OpenAI; set for DeepSeek/Groq/Ollama
LLM_MODEL=deepseek-chat               # e.g. gpt-4o, claude-haiku-4-5-20251001, deepseek-chat
LLM_BATCH_SIZE=50                     # raw items sent per LLM call
